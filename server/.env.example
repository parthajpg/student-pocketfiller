# Environment Variables — Student Pocket Filler Backend
# ─────────────────────────────────────────────────────
# INSTRUCTIONS:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in every value
#   3. NEVER commit .env to git — it's in .gitignore
# ─────────────────────────────────────────────────────

# ── PostgreSQL (Render free tier) ─────────────────────
# Get this from: Render Dashboard → your Postgres DB → Connection → External URL
DATABASE_URL=postgresql://username:password@oregon-postgres.render.com:5432/dbname

# ── JWT Secret ────────────────────────────────────────
# Generate one: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-this-to-a-very-long-random-secret-at-least-48-chars

# ── CPX Research ──────────────────────────────────────
# App ID is already hardcoded in the frontend (34184)
# Hash Key: CPX Dashboard → App Settings → Security → Hash Key
CPX_APP_ID=34184
CPX_HASH_KEY=your_cpx_hash_key_here
CPX_SECURE_KEY=your_cpx_secure_key_here

# ── CORS — Frontend URL ───────────────────────────────
# Set to your Render static site URL or custom domain in production
FRONTEND_URL=http://localhost:3000

# ── Server ────────────────────────────────────────────
PORT=3001
NODE_ENV=production
